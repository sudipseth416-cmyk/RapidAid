# Server
NODE_ENV=development
PORT=4000
# Comma-separated frontend origins (Vercel production + previews)
CLIENT_URL=http://localhost:3000,https://rapidaid.vercel.app
# Optional extra origins (preview URLs)
ADDITIONAL_CORS_ORIGINS=https://rapidaid-git-main.vercel.app
# MongoDB Atlas (Railway production)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/rapidaid?retryWrites=true&w=majority

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Twilio (phone OTP for citizen + ambulance)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Set to true to log OTP to console instead of sending SMS (dev only)
OTP_DEV_MODE=true

# Email (hospital verification)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=RapidAid <noreply@rapidaid.in>
APP_URL=http://localhost:3000

# Anthropic Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Geospatial
NEAREST_AMBULANCE_RADIUS_KM=20

# Hospital manual approval (POST /api/auth/hospital/:userId/approve)
ADMIN_APPROVAL_KEY=change-me-admin-key
